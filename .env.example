# API base URL (no trailing slash). Leave EMPTY in development so Vite proxies /api to the target below.
# Set this when your API is on another host (e.g. production).
VITE_API_BASE_URL=

# Entity name for the list page (e.g. user → metadata /api/v1/entities/user/metadata and list API).
VITE_ENTITY_NAME=user

# Entity metadata API path. Use full path (e.g. below) or template with {entity_name} to substitute VITE_ENTITY_NAME.
VITE_ENTITY_METADATA_PATH=/api/v1/entities/users/metadata

# In dev, vite.config.ts proxies /api to this URL. Change the port if your backend uses another (e.g. 3000).
# (Edit server.proxy in vite.config.ts to change the target.)
